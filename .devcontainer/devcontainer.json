{
  "name": "CS421 Haskell Dev",
  "image": "mattox/cs421-haskell-dev:latest",

  "workspaceMount": "source=${localWorkspaceFolder},target=/home/student/workspace,type=bind",
  "workspaceFolder": "/home/student/workspace",

  "remoteUser": "student",

  "customizations": {
    "vscode": {
      "extensions": [
        "haskell.haskell",
        "justusadam.language-haskell"
      ]
    }
  },

  "mounts": [
    "source=cs421-ghcup,target=/home/student/.ghcup,type=volume",
    "source=cs421-stack,target=/home/student/.stack,type=volume",
    "source=cs421-cabal,target=/home/student/.cabal,type=volume"
  ]
}